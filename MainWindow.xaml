<Window x:Class="PortaFile.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ports="clr-namespace:System.IO.Ports;assembly=System.IO.Ports"
        xmlns:services="clr-namespace:PortaFile.Services"
        Title="PortaFile" Height="720" Width="1040" MinHeight="620" MinWidth="900"
        AllowDrop="True" Drop="Window_Drop" DragOver="Window_DragOver"
        Background="#101418" Foreground="#E8ECEF">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#E8ECEF" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="MinWidth" Value="120" />
            <Setter Property="Margin" Value="0,4,12,4" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="MinWidth" Value="92" />
            <Setter Property="Padding" Value="14,7" />
            <Setter Property="Margin" Value="0,4,8,4" />
        </Style>
        <Style TargetType="ProgressBar">
            <Setter Property="Height" Value="16" />
            <Setter Property="Foreground" Value="#2F9E73" />
            <Setter Property="Background" Value="#29323A" />
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" BorderBrush="#2A343D" BorderThickness="1" CornerRadius="6" Padding="14" Background="#151B21">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBlock Text="PortaFile" FontSize="24" FontWeight="SemiBold" />
                <TextBlock Grid.Row="1" Margin="0,6,0,0" Foreground="#AEB8C1"
                           Text="COMポート経由のファイル/フォルダ転送。双方で接続後、ここへドロップして送信します。" />
            </Grid>
        </Border>

        <Border Grid.Row="1" Margin="0,14,0,14" BorderBrush="#2A343D" BorderThickness="1" CornerRadius="6" Padding="14" Background="#151B21">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <WrapPanel>
                    <TextBlock Text="COM" Margin="0,0,8,0" />
                    <ComboBox x:Name="PortComboBox" />
                    <Button Content="更新" Click="RefreshPorts_Click" MinWidth="70" />

                    <TextBlock Text="速度" Margin="18,0,8,0" />
                    <ComboBox x:Name="BaudRateComboBox" />

                    <TextBlock Text="パリティ" Margin="18,0,8,0" />
                    <ComboBox x:Name="ParityComboBox">
                        <ComboBoxItem Content="None" Tag="{x:Static ports:Parity.None}" IsSelected="True" />
                        <ComboBoxItem Content="Odd" Tag="{x:Static ports:Parity.Odd}" />
                        <ComboBoxItem Content="Even" Tag="{x:Static ports:Parity.Even}" />
                    </ComboBox>

                    <TextBlock Text="通信" Margin="18,0,8,0" />
                    <ComboBox x:Name="DuplexComboBox">
                        <ComboBoxItem Content="全二重" Tag="{x:Static services:DuplexMode.FullDuplex}" IsSelected="True" />
                        <ComboBoxItem Content="半二重" Tag="{x:Static services:DuplexMode.HalfDuplex}" />
                    </ComboBox>

                    <TextBlock Text="半二重制御" Margin="18,0,8,0" />
                    <ComboBox x:Name="HalfDuplexControlComboBox">
                        <ComboBoxItem Content="ドライバ任せ" Tag="{x:Static services:HalfDuplexControl.DriverManaged}" IsSelected="True" />
                        <ComboBoxItem Content="RTS制御" Tag="{x:Static services:HalfDuplexControl.Rts}" />
                    </ComboBox>
                </WrapPanel>

                <WrapPanel Grid.Row="1" Margin="0,10,0,0">
                    <Button x:Name="ConnectButton" Content="接続" Click="Connect_Click" />
                    <Button x:Name="DisconnectButton" Content="切断" Click="Disconnect_Click" IsEnabled="False" />
                    <Button x:Name="CancelButton" Content="キャンセル" Click="Cancel_Click" IsEnabled="False" />
                    <TextBlock x:Name="ConnectionText" Margin="12,0,0,0" Foreground="#AEB8C1" Text="未接続" />
                </WrapPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" MinHeight="118" BorderBrush="#3A4650" BorderThickness="2" CornerRadius="6" Padding="18"
                    Background="#172029">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="ファイルまたはフォルダをドロップ" FontSize="22" FontWeight="SemiBold" HorizontalAlignment="Center" />
                    <TextBlock Text="接続済みの相手へ、相対パスと更新日時を保持して送信します"
                               Foreground="#AEB8C1" Margin="0,8,0,0" HorizontalAlignment="Center" />
                </StackPanel>
            </Border>

            <Grid Grid.Row="1" Margin="0,14,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                    <DockPanel>
                        <TextBlock Text="全体" Width="96" />
                        <TextBlock Text="{Binding OverallPercent, StringFormat={}{0:0.0}%}" HorizontalAlignment="Right" DockPanel.Dock="Right" />
                    </DockPanel>
                    <ProgressBar Value="{Binding OverallPercent}" Maximum="100" />
                </StackPanel>
                <StackPanel Grid.Column="1" Margin="8,0,0,0">
                    <DockPanel>
                        <TextBlock Text="現在ファイル" Width="96" />
                        <TextBlock Text="{Binding FilePercent, StringFormat={}{0:0.0}%}" HorizontalAlignment="Right" DockPanel.Dock="Right" />
                    </DockPanel>
                    <ProgressBar Value="{Binding FilePercent}" Maximum="100" />
                </StackPanel>
            </Grid>

            <Border Grid.Row="2" BorderBrush="#2A343D" BorderThickness="1" CornerRadius="6" Padding="12" Background="#151B21">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Blocks}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Rectangle Width="12" Height="12" Margin="2" Fill="{Binding Fill}" RadiusX="1" RadiusY="1" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>
        </Grid>

        <Border Grid.Row="3" Margin="0,14,0,0" BorderBrush="#2A343D" BorderThickness="1" CornerRadius="6" Padding="12" Background="#151B21">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="3*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="状態" Foreground="#AEB8C1" />
                    <TextBlock Text="{Binding Status}" FontWeight="SemiBold" />
                </StackPanel>
                <StackPanel Grid.Column="1">
                    <TextBlock Text="現在のファイル" Foreground="#AEB8C1" />
                    <TextBlock Text="{Binding CurrentFile}" TextTrimming="CharacterEllipsis" />
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="速度" Foreground="#AEB8C1" />
                    <TextBlock Text="{Binding SpeedText}" />
                </StackPanel>
                <StackPanel Grid.Column="3">
                    <TextBlock Text="再送" Foreground="#AEB8C1" />
                    <TextBlock Text="{Binding RetryCount}" />
                </StackPanel>
                <StackPanel Grid.Column="4">
                    <TextBlock Text="エラー" Foreground="#AEB8C1" />
                    <TextBlock Text="{Binding ErrorCount}" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
