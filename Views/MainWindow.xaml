<Window x:Class="PortaFile.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:behaviors="clr-namespace:PortaFile.Views.Behaviors"
        Title="PortaFile" Height="720" Width="1040" MinHeight="620" MinWidth="900"
        Icon="/Assets/AppIcon.ico"
        AllowDrop="True"
        behaviors:DragDropBehavior.DragOverCommand="{Binding DragOverCommand}"
        behaviors:DragDropBehavior.DropCommand="{Binding DropCommand}"
        Background="#F4F7FA" Foreground="#17212B">

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Margin="0,0,0,14" BorderBrush="#D6DEE6" BorderThickness="1" CornerRadius="6" Padding="14" Background="#FFFFFF">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <WrapPanel>
                    <TextBlock Text="{Binding Localization.Label_Port}" Margin="0,0,8,0" />
                    <ComboBox ItemsSource="{Binding PortNames}"
                              SelectedItem="{Binding SelectedPortName}"
                              IsEnabled="{Binding IsSettingsEnabled}" />
                    <Button Content="{Binding Localization.Button_Refresh}" Command="{Binding RefreshPortsCommand}" MinWidth="70" />

                    <TextBlock Text="{Binding Localization.Label_BaudRate}" Margin="18,0,8,0" />
                    <ComboBox ItemsSource="{Binding BaudRates}"
                              SelectedItem="{Binding SelectedBaudRate}"
                              IsEnabled="{Binding IsSettingsEnabled}" />
                </WrapPanel>

                <WrapPanel Grid.Row="1" Margin="0,10,0,0">
                    <TextBlock Text="{Binding Localization.Label_ReliabilityMode}" Margin="0,0,8,0" />
                    <ComboBox ItemsSource="{Binding ReliabilityModes}"
                              DisplayMemberPath="DisplayName"
                              SelectedValuePath="Value"
                              SelectedValue="{Binding SelectedReliabilityMode}"
                              IsEnabled="{Binding IsSettingsEnabled}" />

                    <TextBlock Text="{Binding Localization.Label_DuplexMode}" Margin="18,0,8,0" />
                    <ComboBox ItemsSource="{Binding DuplexModes}"
                              DisplayMemberPath="DisplayName"
                              SelectedValuePath="Value"
                              SelectedValue="{Binding SelectedDuplexMode}"
                              IsEnabled="{Binding IsSettingsEnabled}" />

                    <TextBlock Text="{Binding Localization.Label_HalfDuplexControl}" Margin="18,0,8,0" />
                    <ComboBox ItemsSource="{Binding HalfDuplexControls}"
                              DisplayMemberPath="DisplayName"
                              SelectedValuePath="Value"
                              SelectedValue="{Binding SelectedHalfDuplexControl}"
                              IsEnabled="{Binding IsSettingsEnabled}" />
                </WrapPanel>

                <Grid Grid.Row="2" Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <WrapPanel Grid.Column="0">
                        <Button Content="{Binding Localization.Button_Connect}" Command="{Binding ConnectCommand}" />
                        <Button Content="{Binding Localization.Button_Disconnect}" Command="{Binding DisconnectCommand}" />
                        <Button Content="{Binding Localization.Button_Cancel}" Command="{Binding CancelCommand}" />
                    </WrapPanel>
                    <WrapPanel Grid.Column="1" HorizontalAlignment="Right">
                        <Button Content="{Binding Localization.Button_SelectFile}" Command="{Binding SelectFileCommand}" MinWidth="130" />
                        <Button Content="{Binding Localization.Button_OpenDownloads}" Command="{Binding OpenDownloadsCommand}" MinWidth="130" />
                    </WrapPanel>
                </Grid>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" MinHeight="118" BorderThickness="2" CornerRadius="6" Padding="18">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="BorderBrush" Value="{Binding Progress.DirectionAccent}" />
                        <Setter Property="Background" Value="{Binding Progress.DirectionPanelBackground}" />
                        <Style.Triggers>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsConnected}" Value="True" />
                                    <Condition Binding="{Binding Progress.Direction}" Value="Idle" />
                                </MultiDataTrigger.Conditions>
                                <Setter Property="BorderBrush" Value="{StaticResource ConnectedAccentBrush}" />
                                <Setter Property="Background" Value="{StaticResource ConnectedPanelBackgroundBrush}" />
                            </MultiDataTrigger>
                            <DataTrigger Binding="{Binding IsConnected}" Value="False">
                                <Setter Property="BorderBrush" Value="#C8D1DA" />
                                <Setter Property="Background" Value="#EEF2F5" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="900">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Progress.Direction}" Value="Idle">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <TextBlock Text="{Binding Localization.Label_DropFiles}" FontSize="20" FontWeight="SemiBold" HorizontalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                    <Setter Property="Foreground" Value="#17212B" />
                                    <Style.Triggers>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding IsConnected}" Value="True" />
                                                <Condition Binding="{Binding Progress.Direction}" Value="Idle" />
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Foreground" Value="{StaticResource ConnectedAccentBrush}" />
                                        </MultiDataTrigger>
                                        <DataTrigger Binding="{Binding IsConnected}" Value="False">
                                            <Setter Property="Foreground" Value="#8E9DAB" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock Text="{Binding Localization.Label_Description}"
                                   Margin="0,8,0,0" HorizontalAlignment="Center" TextAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                    <Setter Property="Foreground" Value="#617181" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsConnected}" Value="False">
                                            <Setter Property="Foreground" Value="#9AA7B4" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>

                    <Grid Width="880">
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Progress.Direction}" Value="Idle">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="64" />
                                <ColumnDefinition Width="142" />
                                <ColumnDefinition Width="52" />
                                <ColumnDefinition Width="330" />
                                <ColumnDefinition Width="70" />
                                <ColumnDefinition Width="62" />
                                <ColumnDefinition Width="80" />
                                <ColumnDefinition Width="60" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding Localization.Label_Status}" Foreground="#617181" />
                            <TextBlock Grid.Column="1" Text="{Binding Progress.Status}" FontWeight="SemiBold" Foreground="{Binding Progress.DirectionAccent}" TextTrimming="CharacterEllipsis" />
                            <TextBlock Grid.Column="2" Text="{Binding Localization.Label_Target}" Foreground="#617181" />
                            <TextBlock Grid.Column="3" Text="{Binding Progress.DropZoneTargetText}" TextTrimming="CharacterEllipsis" />
                            <TextBlock Grid.Column="4" Text="{Binding Localization.Label_Files}" Foreground="#617181" />
                            <TextBlock Grid.Column="5" Text="{Binding Progress.TransferFileCount}" FontFamily="Consolas" TextAlignment="Right" />
                            <TextBlock Grid.Column="6" Text="{Binding Localization.Label_Folders}" Foreground="#617181" />
                            <TextBlock Grid.Column="7" Text="{Binding Progress.TransferFolderCount}" FontFamily="Consolas" TextAlignment="Right" />
                        </Grid>

                        <Grid Grid.Row="1" Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="64" />
                                <ColumnDefinition Width="142" />
                                <ColumnDefinition Width="76" />
                                <ColumnDefinition Width="250" />
                                <ColumnDefinition Width="70" />
                                <ColumnDefinition Width="62" />
                                <ColumnDefinition Width="80" />
                                <ColumnDefinition Width="60" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding Localization.Label_Speed}" Foreground="#617181" />
                            <TextBlock Grid.Column="1" Text="{Binding Progress.SpeedText}" FontFamily="Consolas" TextAlignment="Right" />
                            <TextBlock Grid.Column="2" Text="{Binding Localization.Label_Transferred}" Foreground="#617181" />
                            <TextBlock Grid.Column="3" Text="{Binding Progress.DropZoneTransferredText}" FontFamily="Consolas" TextAlignment="Right" />
                            <TextBlock Grid.Column="4" Text="{Binding Localization.Label_Errors}" Foreground="#617181" />
                            <TextBlock Grid.Column="5" Text="{Binding Progress.ErrorCount}" FontFamily="Consolas" TextAlignment="Right" />
                            <TextBlock Grid.Column="6" Text="{Binding Localization.Label_Retries}" Foreground="#617181" />
                            <TextBlock Grid.Column="7" Text="{Binding Progress.RetryCount}" FontFamily="Consolas" TextAlignment="Right" />
                        </Grid>

                        <Grid Grid.Row="2" Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding Localization.Label_CurrentFile}" Foreground="#617181" />
                            <TextBlock Grid.Column="1" Text="{Binding Progress.DropZoneCurrentFileText}" TextTrimming="CharacterEllipsis" />
                        </Grid>
                    </Grid>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="0,14,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                    <DockPanel>
                        <TextBlock Text="{Binding Localization.Label_Overall}" Width="96" />
                        <TextBlock Text="{Binding Progress.OverallPercent, StringFormat={}{0:0.0}%}" HorizontalAlignment="Right" DockPanel.Dock="Right" />
                    </DockPanel>
                    <ProgressBar Value="{Binding Progress.OverallPercent}" Maximum="100">
                        <ProgressBar.Style>
                            <Style TargetType="ProgressBar" BasedOn="{StaticResource {x:Type ProgressBar}}">
                                <Setter Property="Foreground" Value="{Binding Progress.DirectionAccent}" />
                                <Style.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding IsConnected}" Value="True" />
                                            <Condition Binding="{Binding Progress.Direction}" Value="Idle" />
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Foreground" Value="{StaticResource ConnectedAccentBrush}" />
                                    </MultiDataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ProgressBar.Style>
                    </ProgressBar>
                </StackPanel>
                <StackPanel Grid.Column="1" Margin="8,0,0,0">
                    <DockPanel>
                        <TextBlock Text="{Binding Localization.Label_CurrentFileProgress}" Width="96" />
                        <TextBlock Text="{Binding Progress.FilePercent, StringFormat={}{0:0.0}%}" HorizontalAlignment="Right" DockPanel.Dock="Right" />
                    </DockPanel>
                    <ProgressBar Value="{Binding Progress.FilePercent}" Maximum="100">
                        <ProgressBar.Style>
                            <Style TargetType="ProgressBar" BasedOn="{StaticResource {x:Type ProgressBar}}">
                                <Setter Property="Foreground" Value="{Binding Progress.DirectionAccent}" />
                                <Style.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding IsConnected}" Value="True" />
                                            <Condition Binding="{Binding Progress.Direction}" Value="Idle" />
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Foreground" Value="{StaticResource ConnectedAccentBrush}" />
                                    </MultiDataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ProgressBar.Style>
                    </ProgressBar>
                </StackPanel>
            </Grid>

            <Border Grid.Row="2" BorderBrush="#D6DEE6" BorderThickness="1" CornerRadius="6" Padding="12" Background="#FFFFFF">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Progress.Blocks}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Rectangle Width="12" Height="12" Margin="2" Fill="{Binding Fill}" RadiusX="1" RadiusY="1" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>
        </Grid>

    </Grid>
</Window>
