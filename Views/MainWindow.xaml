<Window x:Class="PortaFile.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PortaFile" Height="720" Width="1040" MinHeight="620" MinWidth="900"
        Icon="/Assets/AppIcon.ico"
        AllowDrop="True" Drop="Window_Drop" DragOver="Window_DragOver"
        Background="#F4F7FA" Foreground="#17212B">
    <Window.Resources>
        <SolidColorBrush x:Key="ControlBackgroundBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="ControlHoverBrush" Color="#EEF4FA" />
        <SolidColorBrush x:Key="ControlPressedBrush" Color="#DDEAF5" />
        <SolidColorBrush x:Key="ControlDisabledBrush" Color="#EDF1F5" />
        <SolidColorBrush x:Key="ControlBorderBrush" Color="#B8C4CF" />
        <SolidColorBrush x:Key="ControlTextBrush" Color="#17212B" />
        <SolidColorBrush x:Key="ControlMutedTextBrush" Color="#7A8794" />
        <SolidColorBrush x:Key="ConnectedAccentBrush" Color="#0284C7" />
        <SolidColorBrush x:Key="ConnectedPanelBackgroundBrush" Color="#E0F2FE" />
        <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#FFFFFF" />
        <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="#FFFFFF" />
        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#2370B8" />
        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#FFFFFF" />
        <SolidColorBrush x:Key="{x:Static SystemColors.ControlTextBrushKey}" Color="#17212B" />
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#17212B" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="MinWidth" Value="120" />
            <Setter Property="Margin" Value="0,4,12,4" />
            <Setter Property="Foreground" Value="{StaticResource ControlTextBrush}" />
            <Setter Property="Background" Value="{StaticResource ControlBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource ControlBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="DropDownToggle"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Focusable="False"
                                          ClickMode="Press"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="{TemplateBinding BorderThickness}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="ComboBorder"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="4">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="30" />
                                                </Grid.ColumnDefinitions>
                                                <ContentPresenter Grid.Column="0"
                                                                  Margin="{TemplateBinding Padding}"
                                                                  HorizontalAlignment="Left"
                                                                  VerticalAlignment="Center"
                                                                  Content="{Binding SelectionBoxItem, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                                  ContentTemplate="{Binding SelectionBoxItemTemplate, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                                  ContentStringFormat="{Binding SelectionBoxItemStringFormat, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                                  RecognizesAccessKey="True" />
                                                <Path Grid.Column="1"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"
                                                      Fill="{StaticResource ControlTextBrush}"
                                                      Data="M 0 0 L 4 4 L 8 0 Z" />
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="ComboBorder" Property="Background" Value="{StaticResource ControlHoverBrush}" />
                                                <Setter TargetName="ComboBorder" Property="BorderBrush" Value="#8FA5B8" />
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="ComboBorder" Property="Background" Value="{StaticResource ControlPressedBrush}" />
                                            </Trigger>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter TargetName="ComboBorder" Property="Background" Value="{StaticResource ControlDisabledBrush}" />
                                                <Setter TargetName="ComboBorder" Property="BorderBrush" Value="#D1DAE2" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>

                            <Popup x:Name="Popup"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   PopupAnimation="Fade">
                                <Border Background="{StaticResource ControlBackgroundBrush}"
                                        BorderBrush="{StaticResource ControlBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <ScrollViewer CanContentScroll="True">
                                        <ItemsPresenter />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{StaticResource ControlMutedTextBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{StaticResource ControlTextBrush}" />
            <Setter Property="Background" Value="{StaticResource ControlBackgroundBrush}" />
            <Setter Property="Padding" Value="8,5" />
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="#2370B8" />
                    <Setter Property="Foreground" Value="#FFFFFF" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#1F5F99" />
                    <Setter Property="Foreground" Value="#FFFFFF" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="Button">
            <Setter Property="MinWidth" Value="92" />
            <Setter Property="Padding" Value="14,7" />
            <Setter Property="Margin" Value="0,4,8,4" />
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Foreground" Value="{StaticResource ControlTextBrush}" />
            <Setter Property="Background" Value="{StaticResource ControlBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource ControlBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{StaticResource ControlHoverBrush}" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#8FA5B8" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{StaticResource ControlPressedBrush}" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#6F91AD" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{StaticResource ControlMutedTextBrush}" />
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{StaticResource ControlDisabledBrush}" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#D1DAE2" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ProgressBar">
            <Setter Property="Height" Value="16" />
            <Setter Property="Foreground" Value="#2F9E73" />
            <Setter Property="Background" Value="#E3EAF0" />
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Margin="0,0,0,14" BorderBrush="#D6DEE6" BorderThickness="1" CornerRadius="6" Padding="14" Background="#FFFFFF">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <WrapPanel>
                    <TextBlock Text="COM" Margin="0,0,8,0" />
                    <ComboBox ItemsSource="{Binding PortNames}"
                              SelectedItem="{Binding SelectedPortName}"
                              IsEnabled="{Binding IsSettingsEnabled}" />
                    <Button Content="更新" Command="{Binding RefreshPortsCommand}" MinWidth="70" />

                    <TextBlock Text="速度" Margin="18,0,8,0" />
                    <ComboBox ItemsSource="{Binding BaudRates}"
                              SelectedItem="{Binding SelectedBaudRate}"
                              IsEnabled="{Binding IsSettingsEnabled}" />
                </WrapPanel>

                <WrapPanel Grid.Row="1" Margin="0,10,0,0">
                    <TextBlock Text="転送方式" Margin="0,0,8,0" />
                    <ComboBox ItemsSource="{Binding ReliabilityModes}"
                              DisplayMemberPath="DisplayName"
                              SelectedValuePath="Value"
                              SelectedValue="{Binding SelectedReliabilityMode}"
                              IsEnabled="{Binding IsSettingsEnabled}" />

                    <TextBlock Text="通信" Margin="18,0,8,0" />
                    <ComboBox ItemsSource="{Binding DuplexModes}"
                              DisplayMemberPath="DisplayName"
                              SelectedValuePath="Value"
                              SelectedValue="{Binding SelectedDuplexMode}"
                              IsEnabled="{Binding IsSettingsEnabled}" />

                    <TextBlock Text="半二重制御" Margin="18,0,8,0" />
                    <ComboBox ItemsSource="{Binding HalfDuplexControls}"
                              DisplayMemberPath="DisplayName"
                              SelectedValuePath="Value"
                              SelectedValue="{Binding SelectedHalfDuplexControl}"
                              IsEnabled="{Binding IsSettingsEnabled}" />
                </WrapPanel>

                <Grid Grid.Row="2" Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <WrapPanel Grid.Column="0">
                        <Button Content="接続" Command="{Binding ConnectCommand}" />
                        <Button Content="切断" Command="{Binding DisconnectCommand}" />
                        <Button Content="キャンセル" Command="{Binding CancelCommand}" />
                    </WrapPanel>
                    <WrapPanel Grid.Column="1" HorizontalAlignment="Right">
                        <Button Content="送信ファイルを選択" Command="{Binding SelectFileCommand}" MinWidth="130" />
                        <Button Content="受信したフォルダを開く" Command="{Binding OpenDownloadsCommand}" MinWidth="130" />
                    </WrapPanel>
                </Grid>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" MinHeight="118" BorderThickness="2" CornerRadius="6" Padding="18">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="BorderBrush" Value="{Binding Progress.DirectionAccent}" />
                        <Setter Property="Background" Value="{Binding Progress.DirectionPanelBackground}" />
                        <Style.Triggers>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsConnected}" Value="True" />
                                    <Condition Binding="{Binding Progress.Direction}" Value="Idle" />
                                </MultiDataTrigger.Conditions>
                                <Setter Property="BorderBrush" Value="{StaticResource ConnectedAccentBrush}" />
                                <Setter Property="Background" Value="{StaticResource ConnectedPanelBackgroundBrush}" />
                            </MultiDataTrigger>
                            <DataTrigger Binding="{Binding IsConnected}" Value="False">
                                <Setter Property="BorderBrush" Value="#C8D1DA" />
                                <Setter Property="Background" Value="#EEF2F5" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="900">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Progress.Direction}" Value="Idle">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <TextBlock Text="ファイルまたはフォルダをドロップ" FontSize="20" FontWeight="SemiBold" HorizontalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                    <Setter Property="Foreground" Value="#17212B" />
                                    <Style.Triggers>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding IsConnected}" Value="True" />
                                                <Condition Binding="{Binding Progress.Direction}" Value="Idle" />
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Foreground" Value="{StaticResource ConnectedAccentBrush}" />
                                        </MultiDataTrigger>
                                        <DataTrigger Binding="{Binding IsConnected}" Value="False">
                                            <Setter Property="Foreground" Value="#8E9DAB" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock Text="接続済みの相手へ、相対パスと更新日時を保持して送信します"
                                   Margin="0,8,0,0" HorizontalAlignment="Center" TextAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                    <Setter Property="Foreground" Value="#617181" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsConnected}" Value="False">
                                            <Setter Property="Foreground" Value="#9AA7B4" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>

                    <Grid Width="880">
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Progress.Direction}" Value="Idle">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="64" />
                                <ColumnDefinition Width="142" />
                                <ColumnDefinition Width="52" />
                                <ColumnDefinition Width="330" />
                                <ColumnDefinition Width="70" />
                                <ColumnDefinition Width="62" />
                                <ColumnDefinition Width="80" />
                                <ColumnDefinition Width="60" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="状態" Foreground="#617181" />
                            <TextBlock Grid.Column="1" Text="{Binding Progress.Status}" FontWeight="SemiBold" Foreground="{Binding Progress.DirectionAccent}" TextTrimming="CharacterEllipsis" />
                            <TextBlock Grid.Column="2" Text="対象" Foreground="#617181" />
                            <TextBlock Grid.Column="3" Text="{Binding Progress.DropZoneTargetText}" TextTrimming="CharacterEllipsis" />
                            <TextBlock Grid.Column="4" Text="ファイル" Foreground="#617181" />
                            <TextBlock Grid.Column="5" Text="{Binding Progress.TransferFileCount}" FontFamily="Consolas" TextAlignment="Right" />
                            <TextBlock Grid.Column="6" Text="フォルダ" Foreground="#617181" />
                            <TextBlock Grid.Column="7" Text="{Binding Progress.TransferFolderCount}" FontFamily="Consolas" TextAlignment="Right" />
                        </Grid>

                        <Grid Grid.Row="1" Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="64" />
                                <ColumnDefinition Width="142" />
                                <ColumnDefinition Width="76" />
                                <ColumnDefinition Width="250" />
                                <ColumnDefinition Width="70" />
                                <ColumnDefinition Width="62" />
                                <ColumnDefinition Width="80" />
                                <ColumnDefinition Width="60" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="速度" Foreground="#617181" />
                            <TextBlock Grid.Column="1" Text="{Binding Progress.SpeedText}" FontFamily="Consolas" TextAlignment="Right" />
                            <TextBlock Grid.Column="2" Text="転送済み" Foreground="#617181" />
                            <TextBlock Grid.Column="3" Text="{Binding Progress.DropZoneTransferredText}" FontFamily="Consolas" TextAlignment="Right" />
                            <TextBlock Grid.Column="4" Text="誤り数" Foreground="#617181" />
                            <TextBlock Grid.Column="5" Text="{Binding Progress.ErrorCount}" FontFamily="Consolas" TextAlignment="Right" />
                            <TextBlock Grid.Column="6" Text="再送回数" Foreground="#617181" />
                            <TextBlock Grid.Column="7" Text="{Binding Progress.RetryCount}" FontFamily="Consolas" TextAlignment="Right" />
                        </Grid>

                        <Grid Grid.Row="2" Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="現在処理中" Foreground="#617181" />
                            <TextBlock Grid.Column="1" Text="{Binding Progress.DropZoneCurrentFileText}" TextTrimming="CharacterEllipsis" />
                        </Grid>
                    </Grid>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="0,14,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                    <DockPanel>
                        <TextBlock Text="全体" Width="96" />
                        <TextBlock Text="{Binding Progress.OverallPercent, StringFormat={}{0:0.0}%}" HorizontalAlignment="Right" DockPanel.Dock="Right" />
                    </DockPanel>
                    <ProgressBar Value="{Binding Progress.OverallPercent}" Maximum="100">
                        <ProgressBar.Style>
                            <Style TargetType="ProgressBar" BasedOn="{StaticResource {x:Type ProgressBar}}">
                                <Setter Property="Foreground" Value="{Binding Progress.DirectionAccent}" />
                                <Style.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding IsConnected}" Value="True" />
                                            <Condition Binding="{Binding Progress.Direction}" Value="Idle" />
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Foreground" Value="{StaticResource ConnectedAccentBrush}" />
                                    </MultiDataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ProgressBar.Style>
                    </ProgressBar>
                </StackPanel>
                <StackPanel Grid.Column="1" Margin="8,0,0,0">
                    <DockPanel>
                        <TextBlock Text="現在ファイル" Width="96" />
                        <TextBlock Text="{Binding Progress.FilePercent, StringFormat={}{0:0.0}%}" HorizontalAlignment="Right" DockPanel.Dock="Right" />
                    </DockPanel>
                    <ProgressBar Value="{Binding Progress.FilePercent}" Maximum="100">
                        <ProgressBar.Style>
                            <Style TargetType="ProgressBar" BasedOn="{StaticResource {x:Type ProgressBar}}">
                                <Setter Property="Foreground" Value="{Binding Progress.DirectionAccent}" />
                                <Style.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding IsConnected}" Value="True" />
                                            <Condition Binding="{Binding Progress.Direction}" Value="Idle" />
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Foreground" Value="{StaticResource ConnectedAccentBrush}" />
                                    </MultiDataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ProgressBar.Style>
                    </ProgressBar>
                </StackPanel>
            </Grid>

            <Border Grid.Row="2" BorderBrush="#D6DEE6" BorderThickness="1" CornerRadius="6" Padding="12" Background="#FFFFFF">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Progress.Blocks}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Rectangle Width="12" Height="12" Margin="2" Fill="{Binding Fill}" RadiusX="1" RadiusY="1" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>
        </Grid>

    </Grid>
</Window>
